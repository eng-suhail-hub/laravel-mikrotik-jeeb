APP_NAME="MikroTik Card System"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=ar
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ar_SA

APP_TIMEZONE=Asia/Aden

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=mikrotik_cards
DB_USERNAME=root
DB_PASSWORD=

QUEUE_CONNECTION=database

CACHE_STORE=database
SESSION_DRIVER=database
SESSION_LIFETIME=120

LOG_CHANNEL=stack
LOG_LEVEL=debug

MIKROTIK_DEFAULT_PORT=8728
MIKROTIK_CONNECTION_TIMEOUT=10
MIKROTIK_QUEUE_LOCK_KEY=mikrotik_connection_lock

JEEB_WEBHOOK_SECRET=change-this-strong-secret-key
JEEB_EMULATOR_PACKAGE=com.jeeb.wallet
JEEB_REGISTRATION_WARNING="يجب أن يكون الاسم الرباعي ورقم الهاتف مطابقين تماماً لبيانات حسابك في محفظة جيب، وإلا لن يتم توليد الكرت."

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@mikrotik-cards.local"
MAIL_FROM_NAME="${APP_NAME}"

INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=admin123
INITIAL_ADMIN_NAME="المسؤول الرئيسي"
